{
  "name": "freeagent-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for FreeAgent accounting API integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun run tsc",
    "start": "bun dist/index.js",
    "dev": "bun run tsc --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "freeagent",
    "accounting",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@vercel/node": "^5.7.4",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "22.x"
  }
}
